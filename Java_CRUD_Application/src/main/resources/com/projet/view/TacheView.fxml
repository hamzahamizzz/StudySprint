<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.projet.controller.TacheController">
    <center>
        <TableView fx:id="tableTaches" prefWidth="550">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                <TableColumn fx:id="colTitre" text="Titre" prefWidth="150" />
                <TableColumn fx:id="colDuree" text="Durée" prefWidth="100" />
                <TableColumn fx:id="colPriorite" text="Priorité" prefWidth="100" />
                <TableColumn fx:id="colStatut" text="Statut" prefWidth="100" />
            </columns>
        </TableView>
    </center>
    <right>
        <VBox spacing="10" style="-fx-padding: 10;" prefWidth="250">
            <Label text="Ajouter / Modifier Tâche" style="-fx-font-weight: bold;" />
            <TextField fx:id="txtTitre" promptText="Titre de la tâche" />
            <TextField fx:id="txtDuree" promptText="Durée (en heures)" />
            <ComboBox fx:id="cbPriorite" promptText="Priorité" prefWidth="150" />
            <ComboBox fx:id="cbStatut" promptText="Statut" prefWidth="150" />
            <TextField fx:id="txtObjectifId" promptText="ID de l'Objectif" />
            <HBox spacing="10" alignment="CENTER">
                <Button text="Ajouter" onAction="#handleAjouter" />
                <Button text="Modifier" onAction="#handleModifier" />
            </HBox>
            <Button text="Supprimer sélection" onAction="#handleSupprimer" style="-fx-text-fill: red;" />
        </VBox>
    </right>
</BorderPane>
