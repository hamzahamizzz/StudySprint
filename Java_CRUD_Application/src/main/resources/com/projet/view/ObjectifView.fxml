<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.projet.controller.ObjectifController">
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <FlowPane fx:id="cardsContainer" hgap="15" vgap="15" style="-fx-padding: 20;" />
        </ScrollPane>
    </center>
    <right>
        <VBox spacing="10" style="-fx-padding: 10;" prefWidth="250">
            <Label text="Ajouter / Modifier Objectif" style="-fx-font-weight: bold;" />
            <TextField fx:id="txtTitre" promptText="Titre de l'objectif" />
            <TextArea fx:id="txtDescription" promptText="Description" prefRowCount="3" />
            <DatePicker fx:id="dpDateDebut" promptText="Date de début" />
            <DatePicker fx:id="dpDateFin" promptText="Date de fin" />
            <ComboBox fx:id="cbStatut" prefWidth="150" />
            <HBox spacing="10" alignment="CENTER">
                <Button text="Ajouter" onAction="#handleAjouter" />
                <Button text="Modifier" onAction="#handleModifier" />
            </HBox>
            <Button text="Annuler Sélection" onAction="#clearForm" />
        </VBox>
    </right>
</BorderPane>
