<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.studysprint.modules.matieres.controllers.ChapitreSelectionController"
            stylesheets="@../../styles/groupes-light-blue.css"
            styleClass="group-page">

    <top>
        <VBox spacing="0" styleClass="header-shell">
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="header-bar">
                <padding><Insets top="10" right="24" bottom="10" left="24"/></padding>
                <Label text="StudySprint - Résumé PDF" styleClass="header-title" />
                <Region HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" styleClass="content-area">
            <padding><Insets top="16" right="24" bottom="20" left="24"/></padding>
            <Label fx:id="matiereLabel" styleClass="group-title" />
            <ScrollPane fitToWidth="true" styleClass="cards-scroll">
                <content>
                    <VBox fx:id="chapitresCheckBoxContainer" spacing="10" styleClass="detail-side-card" />
                </content>
            </ScrollPane>
            <Button fx:id="genererPdfButton" text="Générer le PDF" onAction="#onGenererPdf" styleClass="create-btn" />
        </VBox>
    </center>
</BorderPane>