<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>

<GridPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.example.studysprint.modules.matieres.controllers.MatiereFormController"
          hgap="10" vgap="10" styleClass="group-form-root">
    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

    <Label text="Nom" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="nameField" promptText="Nom de la matière" styleClass="field-input" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

    <Label text="Code" styleClass="field-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <TextField fx:id="codeField" promptText="Code unique (optionnel)" styleClass="field-input" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Description" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <TextArea fx:id="descriptionField" promptText="Description" prefRowCount="4" styleClass="field-input" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
</GridPane>