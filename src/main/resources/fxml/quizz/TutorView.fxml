<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.studysprint.modules.quizz.controllers.TutorController"
      spacing="0"
      prefWidth="700" prefHeight="520">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:#1976D2; -fx-padding:16;">
        <Label fx:id="lblHeaderTitle"
               text="Tuteur IA"
               style="-fx-text-fill:white; -fx-font-size:16; -fx-font-weight:bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblHeaderScore"
               text="0/0"
               style="-fx-text-fill:white; -fx-font-size:12;"/>
    </HBox>

    <!-- Chat scroll area -->
    <ScrollPane fx:id="chatScroll"
                fitToWidth="true"
                VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent; -fx-background:transparent;">
        <VBox fx:id="chatBox"
              spacing="12"
              style="-fx-background-color:#FAFAFA;">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
        </VBox>
    </ScrollPane>

    <!-- Loading indicator -->
    <Label fx:id="loadingLabel"
           text="Mistral réfléchit…"
           visible="false"
           managed="false"
           style="-fx-text-fill:#9E9E9E; -fx-font-style:italic; -fx-padding:4 16 4 16;"/>

    <!-- Input bar -->
    <HBox spacing="8" alignment="CENTER"
          style="-fx-background-color:#F5F5F5; -fx-padding:12;">
        <TextField fx:id="userInput"
                   promptText="Posez votre question…"
                   HBox.hgrow="ALWAYS"/>
        <Button fx:id="sendBtn"
                text="Envoyer"
                style="-fx-background-color:#1976D2; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:6;"/>
    </HBox>

</VBox>
