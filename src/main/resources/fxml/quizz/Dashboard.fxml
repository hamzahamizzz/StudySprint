<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.studysprint.modules.quizz.controllers.DashboardController"
            prefWidth="980" prefHeight="720"
            style="-fx-background-color:#F7FFFC;">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color:#FFFFFF;
                     -fx-border-color:transparent transparent #E5EAF2 transparent;
                     -fx-border-width:0 0 1 0;
                     -fx-padding:16 24;">
            <VBox spacing="2">
                <Label text="TABLEAU DE BORD"
                       style="-fx-font-size:11;-fx-font-weight:bold;
                              -fx-text-fill:#B0BBC8;-fx-letter-spacing:0.12em;"/>
                <Label text="Vue d'ensemble"
                       style="-fx-font-size:20;-fx-font-weight:bold;-fx-text-fill:#4A5673;"/>
            </VBox>
        </HBox>
    </top>

    <center>
        <StackPane>

            <!-- Loading spinner — visible until data is ready -->
            <ProgressIndicator fx:id="loadingSpinner"
                               maxWidth="64" maxHeight="64"/>

            <!-- Main content — hidden until buildUI() runs -->
            <ScrollPane fitToWidth="true"
                        style="-fx-background-color:transparent;-fx-border-color:transparent;">
                <VBox fx:id="contentBox" spacing="20"
                      style="-fx-padding:24;">
                    <!-- Populated programmatically by DashboardController.buildUI() -->
                </VBox>
            </ScrollPane>

        </StackPane>
    </center>

</BorderPane>
