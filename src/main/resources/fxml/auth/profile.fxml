<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.studysprint.modules.auth.controllers.ProfileController" stylesheets="@../../styles/main.css">
   <children>
      <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="300.0" spacing="30.0" style="-fx-background-color: #6c5ce7;">
         <children>
            <VBox alignment="CENTER" spacing="10.0">
               <children>
                  <VBox alignment="CENTER" prefHeight="100.0" prefWidth="100.0" style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 50;">
                     <children>
                        <Label text="👤" textFill="WHITE">
                           <font>
                              <Font size="48.0" />
                           </font>
                        </Label>
                     </children>
                     <maxWidth>100.0</maxWidth>
                  </VBox>
                  <Label fx:id="fullNameLabel" text="Jean Dupont" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                  </Label>
                  <Label fx:id="roleLabel" text="Étudiant" textFill="#dfe6e9">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
               <VBox.margin>
                  <Insets top="50.0" />
               </VBox.margin>
            </VBox>
            <VBox spacing="10.0" VBox.vgrow="ALWAYS">
               <children>
                  <Button maxWidth="Infinity" style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20;" text="Mon Profil" />
                  <Button maxWidth="Infinity" onAction="#handleChangePassword" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-cursor: hand;" text="🔑  Changer le mot de passe" />
                  <Button maxWidth="Infinity" onAction="#handleFaceId" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-cursor: hand;" text="👁  Configurer mon Face ID" />
               </children>
               <padding>
                  <Insets left="20.0" right="20.0" />
               </padding>
            </VBox>
            <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="40.0" prefWidth="240.0" style="-fx-background-color: transparent; -fx-border-color: white; -fx-border-radius: 20; -fx-text-fill: white;" text="Déconnexion">
               <VBox.margin>
                  <Insets bottom="40.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
      <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS" style="-fx-background-color: #f9f9f9; -fx-background: #f9f9f9;">
         <content>
            <VBox spacing="30.0">
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="20.0">
                     <children>
                        <VBox HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Paramètres du profil" textFill="#2d3436">
                                 <font>
                                    <Font name="System Bold" size="28.0" />
                                 </font>
                              </Label>
                              <Label text="Gérez vos informations personnelles et académiques." textFill="#636e72" />
                           </children>
                        </VBox>
                        <Button fx:id="updateButton" mnemonicParsing="false" onAction="#handleUpdate" prefHeight="45.0" prefWidth="180.0" text="Enregistrer les modifications" />
                     </children>
                  </HBox>
                  
                  <VBox spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                     <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                     </padding>
                     <children>
                        <Label text="Informations personnelles" textFill="#2d3436">
                           <font>
                              <Font name="System Bold" size="18.0" />
                           </font>
                        </Label>
                        <GridPane hgap="25.0" vgap="20.0">
                           <children>
                              <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                 <children>
                                    <Label text="Nom" textFill="#636e72" />
                                    <TextField fx:id="nomField" prefHeight="40.0" />
                                    <Label fx:id="nomError" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                 <children>
                                    <Label text="Prénom" textFill="#636e72" />
                                    <TextField fx:id="prenomField" prefHeight="40.0" />
                                    <Label fx:id="prenomError" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                 <children>
                                    <Label text="Email" textFill="#636e72" />
                                    <TextField fx:id="emailField" prefHeight="40.0" styleClass="form-field" />
                                    <Label fx:id="emailError" managed="false" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                 <children>
                                    <Label text="Téléphone" textFill="#636e72" />
                                    <TextField fx:id="telephoneField" prefHeight="40.0" styleClass="form-field" />
                                    <Label fx:id="telephoneError" managed="false" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" />
                                 </children>
                              </VBox>
                           </children>
                        </GridPane>
                     </children>
                  </VBox>

                  <VBox spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                     <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                     </padding>
                     <children>
                        <Label text="Localisation &amp; Établissement" textFill="#2d3436">
                           <font>
                              <Font name="System Bold" size="18.0" />
                           </font>
                        </Label>
                        <VBox spacing="20.0">
                            <children>
                                <VBox spacing="5.0">
                                   <children>
                                      <Label text="Pays" textFill="#636e72" />
                                      <ComboBox fx:id="paysCombo" maxWidth="Infinity" prefHeight="40.0" />
                                   </children>
                                </VBox>
                                <VBox spacing="5.0">
                                   <children>
                                      <Label text="Établissement / Université" textFill="#636e72" />
                                      <ComboBox fx:id="etablissementCombo" maxWidth="Infinity" prefHeight="40.0" />
                                   </children>
                                </VBox>
                            </children>
                        </VBox>
                     </children>
                  </VBox>

                  <VBox fx:id="studentFields" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                     <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                     </padding>
                     <children>
                        <Label text="Détails Étudiant" textFill="#2d3436">
                           <font>
                              <Font name="System Bold" size="18.0" />
                           </font>
                        </Label>
                        <GridPane hgap="25.0" vgap="20.0">
                           <children>
                              <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                 <children>
                                    <Label text="Âge" textFill="#636e72" />
                                    <TextField fx:id="ageField" prefHeight="40.0" promptText="Âge (> 13)" />
                                    <Label fx:id="ageError" managed="false" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                 <children>
                                    <Label text="Sexe" textFill="#636e72" />
                                    <ComboBox fx:id="sexeCombo" maxWidth="Infinity" prefHeight="40.0" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                                 <children>
                                    <Label text="Niveau" textFill="#636e72" />
                                    <ComboBox fx:id="niveauCombo" maxWidth="Infinity" prefHeight="40.0" promptText="Sélectionnez votre niveau" />
                                 </children>
                              </VBox>
                           </children>
                        </GridPane>
                     </children>
                  </VBox>

                  <VBox fx:id="professorFields" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                     <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                     </padding>
                     <children>
                        <Label text="Détails Professeur" textFill="#2d3436">
                           <font>
                              <Font name="System Bold" size="18.0" />
                           </font>
                        </Label>
                        <GridPane hgap="25.0" vgap="20.0">
                           <children>
                              <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2">
                                 <children>
                                    <Label text="Spécialité" textFill="#636e72" />
                                    <TextField fx:id="specialiteField" prefHeight="40.0" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                 <children>
                                    <Label text="Niveau d'enseignement" textFill="#636e72" />
                                    <TextField fx:id="niveauEnseignementField" prefHeight="40.0" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                 <children>
                                    <Label text="Années d'expérience" textFill="#636e72" />
                                    <TextField fx:id="experienceField" prefHeight="40.0" />
                                 </children>
                              </VBox>
                           </children>
                        </GridPane>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</HBox>
