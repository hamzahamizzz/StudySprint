<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.studysprint.modules.auth.controllers.VerifyCodeController" stylesheets="@../../styles/main.css">
   <children>
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="450.0" style="-fx-background-color: #f7f9fc;">
         <children>
            <Label text="StudySprint" textFill="#6c5ce7">
               <font>
                  <Font name="System Bold" size="32.0" />
               </font>
            </Label>
            <Label text="Vérification en cours..." textFill="#a4b0be">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
         </children>
      </VBox>
      <StackPane prefHeight="150.0" prefWidth="450.0" style="-fx-background-color: white;">
         <children>
            <VBox alignment="CENTER_LEFT" maxWidth="350.0" spacing="20.0">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Code de vérification" textFill="#2d3436">
                           <font>
                              <Font name="System Bold" size="24.0" />
                           </font>
                        </Label>
                        <Label fx:id="instructionLabel" text="Entrez le code à 6 chiffres envoyé à votre email." textFill="#636e72" wrapText="true" />
                     </children>
                  </VBox>
                  <VBox spacing="15.0">
                     <children>
                        <VBox spacing="5.0" alignment="CENTER">
                           <children>
                              <TextField fx:id="codeField" alignment="CENTER" maxWidth="250.0" prefHeight="60.0" promptText="000000" style="-fx-font-size: 24px; -fx-letter-spacing: 5px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-border-radius: 10;" />
                              <Label fx:id="codeError" styleClass="error-label" visible="false" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  <VBox spacing="10.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleVerifyCode" prefHeight="50.0" prefWidth="350.0" text="Vérifier le code">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#handleResendCode" prefHeight="35.0" prefWidth="350.0" style="-fx-background-color: transparent; -fx-text-fill: #636e72;" text="Je n'ai pas reçu l'email. Renvoyer." />
                        <Button mnemonicParsing="false" onAction="#handleBackToEmail" prefHeight="45.0" prefWidth="350.0" style="-fx-background-color: transparent; -fx-text-fill: #6c5ce7; -fx-border-color: #6c5ce7; -fx-border-radius: 20; -fx-background-radius: 20;" text="Modifier l'email">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Button>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </StackPane>
   </children>
</HBox>
