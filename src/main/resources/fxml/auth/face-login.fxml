<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="700.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.studysprint.modules.auth.controllers.FaceLoginController">
   <children>
      <VBox alignment="CENTER" spacing="10.0">
         <children>
            <Label text="Connexion par Reconnaissance Faciale" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <Label text="Veuillez rester face à la caméra pour l'identification." textFill="#94a3b8">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
         </children>
      </VBox>
      
      <VBox alignment="CENTER" style="-fx-border-color: #8b5cf6; -fx-border-width: 2; -fx-border-radius: 20; -fx-background-radius: 20; -fx-overflow: hidden;">
         <children>
            <WebView fx:id="webView" minHeight="500.0" minWidth="660.0" prefHeight="500.0" prefWidth="660.0" />
         </children>
      </VBox>
      
      <Label fx:id="statusLabel" text="Initialisation du capteur..." textFill="#8b5cf6">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
      
      <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: #475569; -fx-border-radius: 20;" text="Annuler" />
   </children>
</VBox>
