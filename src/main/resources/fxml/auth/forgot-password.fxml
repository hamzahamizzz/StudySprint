<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.studysprint.modules.auth.controllers.ForgotPasswordController" stylesheets="@../../styles/main.css">
   <children>
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="450.0" styleClass="auth-left-pane">
         <children>
            <Label text="StudySprint" textFill="#6c5ce7">
               <font>
                  <Font name="System Bold" size="32.0" />
               </font>
            </Label>
            <Label text="Sécurité &amp; Confidentialité" textFill="#a4b0be">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
         </children>
      </VBox>
      <StackPane prefHeight="150.0" prefWidth="450.0" styleClass="auth-right-pane">
         <children>
            <VBox alignment="CENTER_LEFT" maxWidth="350.0" spacing="20.0">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Mot de passe oublié ?" textFill="#2d3436">
                           <font>
                              <Font name="System Bold" size="24.0" />
                           </font>
                        </Label>
                        <Label text="Entrez votre email pour recevoir un code de vérification." textFill="#636e72" wrapText="true" />
                     </children>
                  </VBox>
                  <VBox spacing="15.0">
                     <children>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Email" textFill="#2d3436">
                                 <font>
                                    <Font name="System Bold" size="13.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="emailField" prefHeight="45.0" promptText="votre@email.com" />
                              <Label fx:id="emailError" styleClass="error-label" visible="false" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  <VBox spacing="10.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleRequestCode" prefHeight="50.0" prefWidth="350.0" text="Recevoir le code">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#handleBackToLogin" prefHeight="45.0" prefWidth="350.0" styleClass="auth-outline-btn" text="Retour à la connexion">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Button>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </StackPane>
   </children>
</HBox>
