<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.example.studysprint.modules.utilisateurs.controllers.MainAdminController"
            stylesheets="@../../styles/main.css">
    
    <!-- ═══ Sidebar (Left) ═══ -->
    <left>
        <VBox prefWidth="250.0" spacing="10.0" styleClass="bo-sidebar">
            <children>
                <!-- Logo / Title -->
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="bo-logo-row">
                    <children>
                        <Label text="Study" styleClass="bo-brand-study">
                            <font><Font name="System Bold" size="24.0" /></font>
                        </Label>
                        <Label text="Sprint" styleClass="bo-brand-sprint">
                            <font><Font name="System Bold" size="24.0" /></font>
                        </Label>
                    </children>
                </HBox>
                
                <Separator opacity="0.1" styleClass="bo-divider" />
                
                <Label text="NAVIGATION" styleClass="bo-nav-title" />
                
                <Button fx:id="usersBtn" alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" 
                        onAction="#showUsersList" prefHeight="45.0" text="👤  Utilisateurs" 
                        styleClass="bo-sidebar-btn" />

                <Button fx:id="groupsBtn" alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                    onAction="#showGroupsManagement" prefHeight="45.0" text="👥  Groupes"
                    styleClass="bo-sidebar-btn" />
                
                <Button fx:id="statsBtn" alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" 
                        onAction="#showStats" prefHeight="45.0" text="📊  Statistiques" 
                        styleClass="bo-sidebar-btn" />

                <HBox alignment="CENTER_LEFT" spacing="0">
                    <children>
                        <Button fx:id="requestsBtn" alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" 
                                onAction="#showReactivationRequests" prefHeight="45.0" text="🔔  Réactivations" HBox.hgrow="ALWAYS"
                                styleClass="bo-sidebar-btn" />
                        <StackPane fx:id="badgeContainer" visible="false">
                            <children>
                                <Label fx:id="requestBadge" styleClass="bo-badge" text="0" />
                            </children>
                        </StackPane>
                    </children>
                </HBox>
                
                <VBox VBox.vgrow="ALWAYS" /> <!-- Spacer -->
                
                <Separator opacity="0.1" styleClass="bo-divider" />
                
                <!-- Bottom Buttons -->
                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" 
                        onAction="#showMyProfile" prefHeight="45.0" text="⚙ Mon Profil" 
                        styleClass="bo-bottom-profile-btn" />
                
                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" 
                        onAction="#handleLogout" prefHeight="45.0" text="🚪  Déconnexion" 
                        styleClass="bo-bottom-logout-btn" />
            </children>
        </VBox>
    </left>
    
    <!-- ═══ Main Content Area (Center) ═══ -->
    <center>
        <StackPane fx:id="contentArea" styleClass="bo-content-area" />
    </center>
    
</BorderPane>
