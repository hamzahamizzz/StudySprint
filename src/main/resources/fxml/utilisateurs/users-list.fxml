<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.studysprint.modules.utilisateurs.controllers.UsersListController" stylesheets="@../../styles/main.css">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label text="Gestion des Utilisateurs" textFill="#2d3436">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS" spacing="15.0">
                    <children>
                        <TextField fx:id="searchField" promptText="Rechercher (nom, email...)" prefWidth="250.0" />
                        <Button mnemonicParsing="false" onAction="#handleResetSearch" text="✕"
                                style="-fx-background-color: #b2bec3; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand;"
                                prefWidth="32.0" prefHeight="32.0" />
                        <Button mnemonicParsing="false" onAction="#handleAddUser" text="+ Ajouter un Utilisateur" />
                        <Button mnemonicParsing="false" onAction="#handleMyProfile" text="👤 Mon Profil" style="-fx-background-color: #00cec9; -fx-text-fill: white; -fx-background-radius: 20;" />
                        <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-border-color: #d63031; -fx-text-fill: #d63031;" text="Déconnexion" />
                    </children>
                </HBox>
            </children>
        </HBox>
        <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idCol" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="nomCol" prefWidth="120.0" text="Nom" />
                <TableColumn fx:id="prenomCol" prefWidth="120.0" text="Prénom" />
                <TableColumn fx:id="emailCol" prefWidth="180.0" text="Email" />
                <TableColumn fx:id="roleCol" prefWidth="100.0" text="Rôle" />
                <TableColumn fx:id="statutCol" prefWidth="80.0" text="Statut" />
                <TableColumn fx:id="actionsCol" prefWidth="250.0" text="Actions" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
</VBox>
