<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.studysprint.modules.utilisateurs.controllers.AdminProfileController"
      stylesheets="@../../styles/main.css"
    styleClass="admin-profile-root"
      prefWidth="900.0" prefHeight="700.0">

    <!-- ═══ Header Bar ═══ -->
    <HBox alignment="CENTER_LEFT" spacing="15.0"
                    styleClass="admin-profile-header">
        <children>
            <!-- Avatar Circle -->
            <VBox alignment="CENTER"
                  minWidth="50.0" minHeight="50.0" maxWidth="50.0" maxHeight="50.0"
                                    styleClass="admin-profile-avatar-shell">
                <children>
                    <Label fx:id="avatarLabel" textFill="WHITE" text="A">
                        <font><Font name="System Bold" size="20.0" /></font>
                    </Label>
                </children>
            </VBox>

            <VBox spacing="2.0">
                <children>
                    <Label fx:id="fullNameLabel" text="Nom Prénom" textFill="WHITE">
                        <font><Font name="System Bold" size="18.0" /></font>
                    </Label>
                    <Label text="Administrateur" textFill="#dfe6e9" />
                </children>
            </VBox>

            <HBox HBox.hgrow="ALWAYS" />

            <Button mnemonicParsing="false" onAction="#handleBack" text="← Retour au Dashboard"
                    styleClass="admin-profile-back-btn" />
        </children>
    </HBox>

    <!-- ═══ Scrollable Content ═══ -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                styleClass="admin-profile-scroll">
        <content>
            <VBox spacing="25.0" styleClass="admin-profile-content">
                <padding><Insets bottom="40.0" left="60.0" right="60.0" top="40.0" /></padding>
                <children>

                    <!-- ─── Section 1: Informations Personnelles ─── -->
                    <VBox spacing="15.0" styleClass="form-card">
                        <children>
                            <Label styleClass="section-title" text="Informations Personnelles" />
                            <GridPane hgap="25.0" vgap="15.0">
                                <children>
                                    <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                        <Label styleClass="form-label-muted" text="Nom" />
                                        <TextField fx:id="nomField" prefHeight="40.0" promptText="Nom de famille" />
                                    </VBox>
                                    <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                        <Label styleClass="form-label-muted" text="Prénom" />
                                        <TextField fx:id="prenomField" prefHeight="40.0" promptText="Prénom" />
                                    </VBox>
                                    <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                                        <Label styleClass="form-label-muted" text="Adresse Email" />
                                        <TextField fx:id="emailField" prefHeight="40.0" promptText="email@exemple.com" />
                                    </VBox>
                                </children>
                                <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                </columnConstraints>
                            </GridPane>
                        </children>
                    </VBox>

                    <!-- ─── Section 2: Contact & Coordonnées ─── -->
                    <VBox spacing="15.0" styleClass="form-card">
                        <children>
                            <Label styleClass="section-title" text="Contact &amp; Coordonnées" />
                            <GridPane hgap="25.0" vgap="15.0">
                                <children>
                                    <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                        <Label styleClass="form-label-muted" text="Téléphone" />
                                        <TextField fx:id="telField" prefHeight="40.0" promptText="+216..." />
                                    </VBox>
                                    <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                        <Label styleClass="form-label-muted" text="Pays" />
                                        <ComboBox fx:id="paysCombo" prefHeight="40.0" prefWidth="9999.0"
                                                  promptText="Chargement des pays..." />
                                    </VBox>
                                    <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                        <Label styleClass="form-label-muted" text="Âge" />
                                        <TextField fx:id="ageField" prefHeight="40.0" promptText="Ex: 30" />
                                    </VBox>
                                    <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                        <Label styleClass="form-label-muted" text="Sexe" />
                                        <ComboBox fx:id="sexeCombo" prefHeight="40.0" prefWidth="9999.0" />
                                    </VBox>
                                </children>
                                <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                </columnConstraints>
                            </GridPane>
                        </children>
                    </VBox>

                    <!-- ─── Section 3: Informations du Compte (lecture seule) ─── -->
                    <VBox spacing="15.0" styleClass="form-card">
                        <children>
                            <Label styleClass="section-title" text="Informations du Compte" />
                            <GridPane hgap="25.0" vgap="15.0">
                                <children>
                                    <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                        <Label styleClass="form-label-muted" text="Rôle" />
                                        <TextField fx:id="roleField" prefHeight="40.0" editable="false"
                                                   styleClass="readonly-field" />
                                    </VBox>
                                    <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                        <Label styleClass="form-label-muted" text="Date d'inscription" />
                                        <TextField fx:id="dateField" prefHeight="40.0" editable="false"
                                                   styleClass="readonly-field" />
                                    </VBox>
                                    <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                        <Label styleClass="form-label-muted" text="Statut" />
                                        <TextField fx:id="statutField" prefHeight="40.0" editable="false"
                                                   styleClass="readonly-field" />
                                    </VBox>
                                </children>
                                <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                </columnConstraints>
                            </GridPane>
                        </children>
                    </VBox>

                    <!-- ─── Bouton Enregistrer ─── -->
                    <HBox alignment="CENTER_RIGHT" spacing="15.0">
                        <children>
                            <Label fx:id="messageLabel"
                               styleClass="status-message"
                                   visible="false" />
                            <Button mnemonicParsing="false" onAction="#handleFaceEnroll"
                                    prefHeight="44.0" prefWidth="200.0"
                                    text="👤  Sécurité Biométrique"
                                styleClass="outline-violet-btn" />
                            <Button mnemonicParsing="false" onAction="#handleChangePassword"
                                    prefHeight="44.0" prefWidth="220.0"
                                    text="🔑  Changer le mot de passe"
                                styleClass="outline-primary-btn" />
                            <Button mnemonicParsing="false" onAction="#handleSave"
                                    prefHeight="44.0" prefWidth="200.0"
                                    text="💾  Enregistrer"
                                styleClass="save-main-btn" />
                        </children>
                    </HBox>

                </children>
            </VBox>
        </content>
    </ScrollPane>

</VBox>
