<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.studysprint.modules.groupes.controllers.GroupListController"
      stylesheets="@../../styles/main.css"
      styleClass="profile-shell group-page" prefWidth="1280.0" prefHeight="820.0">

    <children>
        <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="300.0" spacing="30.0" styleClass="profile-sidebar">
            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <VBox alignment="CENTER" prefHeight="100.0" prefWidth="100.0" styleClass="profile-avatar-shell">
                            <children>
                                <Label styleClass="profile-avatar-icon" text="👤" textFill="WHITE" />
                            </children>
                        </VBox>
                        <Label fx:id="sidebarFullNameLabel" text="Jean Dupont" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Label>
                        <Label fx:id="sidebarRoleLabel" text="Étudiant" textFill="#dfe6e9">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                    </children>
                    <VBox.margin>
                        <Insets top="50.0" />
                    </VBox.margin>
                </VBox>

                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button maxWidth="Infinity" onAction="#onBackHome" styleClass="profile-menu-btn" text="🏠  Accueil" />
                        <Button maxWidth="Infinity" styleClass="profile-menu-btn profile-menu-btn-active" text="👥  Groupes" />
                        <Button maxWidth="Infinity" onAction="#onOpenProfile" styleClass="profile-menu-btn" text="👤  Mon Profil" />
                        <Button maxWidth="Infinity" onAction="#onOpenChangePassword" styleClass="profile-menu-btn" text="🔑  Changer le mot de passe" />
                    </children>
                    <padding>
                        <Insets left="20.0" right="20.0" />
                    </padding>
                </VBox>

                <Button mnemonicParsing="false" onAction="#onLogout" prefHeight="40.0" prefWidth="240.0" styleClass="profile-logout-btn" text="Déconnexion">
                    <VBox.margin>
                        <Insets bottom="40.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>

        <VBox spacing="16" styleClass="content-area" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="24" right="24" bottom="20" left="24" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="14">
                <Label text="Groupes" styleClass="group-title-xl" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="createGroupButton" text="Créer un groupe" onAction="#onCreateGroup" styleClass="create-btn" />
            </HBox>

            <HBox spacing="24" alignment="CENTER_LEFT" styleClass="tabs-bar">
                <HBox spacing="8" alignment="CENTER_LEFT" styleClass="tab-item">
                    <Button fx:id="groupsTabButton" text="Groupes" onAction="#onGroupsTab" styleClass="tab-btn" />
                    <Label fx:id="groupsTabCountLabel" text="0" styleClass="count-pill" />
                </HBox>

                <HBox spacing="8" alignment="CENTER_LEFT" styleClass="tab-item">
                    <Button fx:id="invitationsTabButton" text="Invitations" onAction="#onInvitationsTab" styleClass="tab-btn" />
                    <Label fx:id="invitationsTabCountLabel" text="0" styleClass="count-pill" />
                </HBox>

                <HBox spacing="8" alignment="CENTER_LEFT" styleClass="tab-item">
                    <Button fx:id="feedbacksTabButton" text="Feedbacks" onAction="#onFeedbacksTab" styleClass="tab-btn" />
                    <Label fx:id="feedbacksTabCountLabel" text="0" styleClass="count-pill" />
                </HBox>
            </HBox>

            <StackPane VBox.vgrow="ALWAYS">
                <VBox fx:id="groupsContentPane" spacing="16">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="searchField" promptText="Rechercher par nom ou matière..." styleClass="search-input" HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="sortCombo" prefWidth="160" styleClass="filter-combo" />
                        <ComboBox fx:id="roleCombo" prefWidth="150" styleClass="filter-combo" />
                    </HBox>

                    <Label fx:id="groupsCountLabel" text="0" styleClass="count-pill" visible="false" managed="false" />

                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="cards-scroll" VBox.vgrow="ALWAYS">
                        <content>
                            <FlowPane fx:id="groupCardsPane" hgap="14" vgap="14" prefWrapLength="1100" styleClass="cards-grid">
                                <padding>
                                    <Insets top="2" right="2" bottom="10" left="2" />
                                </padding>
                            </FlowPane>
                        </content>
                    </ScrollPane>
                </VBox>

                <VBox fx:id="invitationsContentPane" spacing="10" styleClass="empty-panel" visible="false" managed="false">
                    <Label text="Invitations" styleClass="empty-title" />
                    <Label text="La section invitations sera disponible bientôt." styleClass="empty-subtitle" />
                </VBox>

                <VBox fx:id="feedbacksContentPane" spacing="10" styleClass="empty-panel" visible="false" managed="false">
                    <Label text="Feedbacks" styleClass="empty-title" />
                    <Label text="La section feedbacks sera disponible bientôt." styleClass="empty-subtitle" />
                </VBox>
            </StackPane>
        </VBox>
    </children>
</HBox>
