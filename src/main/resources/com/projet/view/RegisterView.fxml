<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.projet.controller.RegisterController"
           stylesheets="@styles.css"
           style="-fx-background-color: #f3f4f6;">

    <VBox alignment="CENTER" spacing="0"
          style="-fx-background-color: white; -fx-background-radius: 16;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.10), 20, 0, 0, 6);
                 -fx-padding: 40 40 36 40;"
          maxWidth="420">

        <Label text="∞ StudySprint"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3b82f6; -fx-padding: 0 0 4 0;" />
        <Label text="Créer un compte"
               style="-fx-font-size: 13px; -fx-text-fill: #9ca3af; -fx-padding: 0 0 24 0;" />

        <Label fx:id="lblError" text=""
               style="-fx-text-fill: #ef4444; -fx-font-size: 12px; -fx-padding: 0 0 8 0;"
               wrapText="true" maxWidth="320" />

        <Label text="Adresse email" styleClass="form-label" style="-fx-padding: 0 0 4 0;" />
        <TextField fx:id="txtEmail" promptText="email@exemple.com"
                   styleClass="form-field"
                   style="-fx-pref-width: 320; -fx-pref-height: 40;" />

        <Region prefHeight="12" />

        <Label text="Mot de passe" styleClass="form-label" style="-fx-padding: 0 0 4 0;" />
        <PasswordField fx:id="txtPassword" promptText="Minimum 6 caractères"
                       styleClass="form-field"
                       style="-fx-pref-width: 320; -fx-pref-height: 40;" />

        <Region prefHeight="12" />

        <Label text="Confirmer le mot de passe" styleClass="form-label" style="-fx-padding: 0 0 4 0;" />
        <PasswordField fx:id="txtConfirm" promptText="Répétez le mot de passe"
                       styleClass="form-field"
                       style="-fx-pref-width: 320; -fx-pref-height: 40;" />

        <Region prefHeight="22" />

        <Button text="Créer mon compte" styleClass="btn-primary"
                style="-fx-pref-width: 320; -fx-pref-height: 42; -fx-font-size: 14px;"
                onAction="#handleRegister" defaultButton="true" />

        <Region prefHeight="14" />

        <HBox alignment="CENTER" spacing="6">
            <Label text="Déjà un compte ?"
                   style="-fx-font-size: 13px; -fx-text-fill: #6b7280;" />
            <Button text="Se connecter" styleClass="btn-light"
                    style="-fx-font-size: 13px; -fx-cursor: hand;"
                    onAction="#goToLogin" />
        </HBox>
    </VBox>
</StackPane>
